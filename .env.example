# ===== App =====
PROJECT_NAME=doongle-api
SECRET_KEY=change-me
ENV=local
ADMIN_SECRET_KEY=change-me
DEBUG=true
TESTING=false

# ===== DB =====
DATABASE_URL=postgresql+asyncpg://test1234:test1234@localhost:5432/dongle

# ===== JWT =====
JWT_SECRET=change-me
JWT_TOKEN_URL=/api/v1/auth/login
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Logging =====
LOG_DIR=logs
LOG_LEVEL=INFO

# ===== CORS =====
# 콤마(,) 구분 또는 JSON 배열
CORS_ORIGINS=http://localhost:3031,http://127.0.0.1:3031

# ===== Kafka =====
# 클러스터 내부: kafka-0.kafka.kafka.svc.cluster.local:9092
# 로컬 개발(클러스터 밖): localhost:9092
KAFKA_BROKER=kafka-0.kafka.kafka.svc.cluster.local:9092
KAFKA_TOPIC=image-jobs

# ===== Storage =====
# 저장소 백엔드 (local | minio)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads
# MinIO(S3 호환). STORAGE_BACKEND=minio 일 때 사용. 버킷은 콘솔에서 미리 생성.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=images
MINIO_SECURE=false

# ===== ClickHouse (옵셔널) =====
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASSWORD=
CH_DB=default
